<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Solo Leveling: Shadow Monarch Gauntlet</title>
    <link href="https://googleapis.com" rel="stylesheet">
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            background-color: #050811;
            color: #e0e6ed;
            font-family: 'Roboto', sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 20px;
            min-height: 100vh;
        }
        h1 {
            font-family: 'Orbitron', sans-serif;
            color: #00d2ff;
            text-shadow: 0 0 10px rgba(0, 210, 255, 0.5);
            margin-bottom: 20px;
            font-size: 26px;
            letter-spacing: 2px;
        }
        #hud-container {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            width: 100%;
            max-width: 950px;
            background: rgba(10, 15, 30, 0.9);
            border: 1px solid #00d2ff;
            box-shadow: 0 0 15px rgba(0, 210, 255, 0.2);
            border-radius: 8px;
            padding: 15px;
            margin-bottom: 20px;
            gap: 15px;
        }
        .hud-column { display: flex; flex-direction: column; gap: 6px; font-size: 14px; }
        .hud-column:nth-child(2) { align-items: center; justify-content: center; font-size: 22px; font-weight: bold; color: #ffbc00; font-family: 'Orbitron', sans-serif; text-align: center; }
        .hud-column:nth-child(3) { align-items: flex-end; }
        
        #combat-view {
            width: 100%;
            max-width: 950px;
            height: 160px;
            background: #0a0f1d;
            border: 1px solid #1e293b;
            border-radius: 8px;
            padding: 15px;
            margin-bottom: 20px;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }
        #combat-view h3 { font-family: 'Orbitron', sans-serif; font-size: 14px; color: #ef4444; border-bottom: 1px solid #1e293b; padding-bottom: 4px;}
        #combat-log { font-size: 13px; color: #a0aec0; overflow-y: auto; flex-grow: 1; font-family: monospace; white-space: pre-wrap; }

        #controls-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            width: 100%;
            max-width: 950px;
            gap: 15px;
        }
        .control-panel {
            background: rgba(10, 15, 30, 0.85);
            border: 1px solid #334155;
            border-radius: 6px;
            padding: 12px;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }
        .control-panel h3 { font-family: 'Orbitron', sans-serif; font-size: 13px; color: #38bdf8; border-bottom: 1px solid #1e293b; padding-bottom: 6px; text-align: center;}
        
        .scrollable-actions {
            display: flex;
            flex-direction: column;
            gap: 6px;
            max-height: 240px;
            overflow-y: auto;
            padding-right: 2px;
        }

        button {
            background: #0f172a;
            color: #cbd5e1;
            border: 1px solid #475569;
            padding: 8px 10px;
            border-radius: 4px;
            cursor: pointer;
            font-size: 11px;
            transition: all 0.2s;
            width: 100%;
            text-align: left;
            font-weight: bold;
        }
        button:hover { background: #1e293b; border-color: #00d2ff; color: #fff; box-shadow: 0 0 8px rgba(0, 210, 255, 0.4); }
        
        #btn-gate {
            background: #1e1b4b; 
            font-weight: bold; 
            border-color: #4f46e5; 
            text-align: center;
            color: #fff;
            font-family: 'Orbitron', sans-serif;
            font-size: 12px;
            padding: 12px 6px;
            margin-top: auto;
        }
        #btn-gate:hover { background: #312e81; border-color: #818cf8; }

        #army-poster {
            width: 100%;
            max-width: 950px;
            background: rgba(10, 15, 30, 0.5);
            border: 1px dashed #334155;
            padding: 10px;
            border-radius: 6px;
            margin-top: 15px;
            font-size: 13px;
            color: #94a3b8;
        }

        #info-system-poster {
            width: 100%;
            max-width: 950px;
            background: rgba(15, 23, 42, 0.8);
            border: 1px solid #38bdf8;
            border-radius: 6px;
            padding: 12px;
            margin-top: 15px;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
            font-size: 11px;
            color: #cbd5e1;
        }
        .poster-sec h4 { font-family: 'Orbitron', sans-serif; color: #00d2ff; margin-bottom: 4px; font-size: 12px; }
        .poster-sec ul { list-style: none; padding-left: 0; }
        .poster-sec li { margin-bottom: 2px; }
    </style>
</head>
<body>

    <h1>THE ARCHITECT'S WEB SYSTEM</h1>

    <!-- Core Player Website HUD Dashboard -->
    <div id="hud-container">
        <div class="hud-column">
            <div>👑 LEVEL: <span id="lbl-level">1</span> (<span id="lbl-xp">0</span>/<span id="lbl-max-xp">100</span> XP)</div>
            <div>📊 STAT POINTS: <span id="lbl-points">0</span></div>
            <div>⚔️ WEAPON: <span id="lbl-weapon">Fists</span></div>
        </div>
        <div class="hud-column">
            FLOOR<br><span id="lbl-floor">1</span>
        </div>
        <div class="hud-column">
            <div>💧 MANA: <span id="lbl-mana">10</span> / <span id="lbl-max-mana">10</span> MP</div>
            <div>💰 GOLD: <span id="lbl-gold">0</span>G</div>
            <div>❤️ HP: <span id="lbl-hp">100</span> / <span id="lbl-max-hp">100</span></div>
        </div>
    </div>

    <!-- Active Text-Based Arena Console Box -->
    <div id="combat-view">
        <h3>📝 SYSTEM MONITOR LOG</h3>
        <div id="combat-log">System Initialized. Welcome, Hunter. Allocate your stats or purchase shadows to begin.</div>
    </div>

    <!-- Interactive Navigation Web Menus -->
    <div id="controls-grid">
        <!-- STAT TUNING -->
        <div class="control-panel">
            <h3>📊 STAT TUNING</h3>
            <div class="scrollable-actions">
                <button onclick="addStat('power')">💪 Power (<span id="stat-power">0</span>) x2 ATK</button>
                <button onclick="addStat('defence')">🛡️ Defence (<span id="stat-defence">0</span>) x2 HP</button>
                <button onclick="addStat('speed')">👟 Speed (<span id="stat-speed">0</span>) +10% Dg</button>
                <button onclick="addStat('mana')">🧪 Mana (<span id="stat-mana">0</span>) +5k Max</button>
            </div>
        </div>
        
        <!-- SHADOW SHOP -->
        <div class="control-panel">
            <h3>🛒 SHADOW SHOP</h3>
            <div class="scrollable-actions">
                <button onclick="buyShadow('Common', 10)">🔮 Common (10 MP)</button>
                <button onclick="buyShadow('Uncommon', 50)">🔮 Uncommon (50 MP)</button>
                <button onclick="buyShadow('Rare', 250)">🔮 Rare (250 MP)</button>
                <button onclick="buyShadow('Epic', 1000)">🔮 Epic (1k MP)</button>
                <button onclick="buyShadow('Legendary', 5000)">🔮 Legendary (5k MP)</button>
                <button onclick="buyShadow('Mythical', 20000)">🔮 Mythical (20k MP)</button>
                <button onclick="buyShadow('Special', 100000)">🔮 Special (100k MP)</button>
                <button onclick="buyShadow('Secret', 300000)">🔮 Secret (300k MP)</button>
                <button onclick="buyShadow('Unique', 600000)">🔮 Unique (600k MP)</button>
                <button onclick="buyShadow('Chroma', 1000000)">🔮 Chroma (1M MP)</button>
            </div>
        </div>
        
        <!-- MERGE CORE -->
        <div class="control-panel">
            <h3>🧬 MERGE CORE</h3>
            <div class="scrollable-actions">
                <button onclick="mergeShadows('Common', 'Uncommon', 5)">🧬 5 Common ➔ 1 Uncom</button>
                <button onclick="mergeShadows('Uncommon', 'Rare', 5)">🧬 5 Uncom ➔ 1 Rare</button>
                <button onclick="mergeShadows('Rare', 'Epic', 4)">🧬 4 Rare ➔ 1 Epic</button>
                <button onclick="mergeShadows('Epic', 'Legendary', 5)">🧬 5 Epic ➔ 1 Leg</button>
                <button onclick="mergeShadows('Legendary', 'Mythical', 4)">🧬 4 Leg ➔ 1 Mythic</button>
                <button onclick="mergeShadows('Mythical', 'Special', 5)">🧬 5 Mythic ➔ 1 Spec</button>
                <button onclick="mergeShadows('Special', 'Secret', 3)">🧬 3 Spec ➔ 1 Secr</button>
                <button onclick="mergeShadows('Secret', 'Unique', 3)">🧬 3 Secr ➔ 1 Uniq</button>
                <button onclick="mergeShadows('Unique', 'Chroma', 3)">🧬 3 Uniq ➔ 1 Chroma</button>
            </div>
        </div>
        
        <!-- MARKET & GATE -->
        <div class="control-panel">
            <h3>🧪 MARKET & GATE</h3>
            <div class="scrollable-actions" style="height:100%; display:flex; flex-direction:column;">
                <button onclick="buyGoldMana(100, 50)">💧 Shard (+50MP) - 100G</button>
                <button onclick="buyGoldMana(400, 250)">💧 Pot (+250MP) - 400G</button>
                <button id="btn-gate" onclick="combatTrigger()">⚔️ ENTER ARENA</button>
            </div>
        </div>
    </div>

    <!-- Bottom Army Tracking Panel -->
    <div id="army-poster">
        📋 <strong>Active Shadow Retainers inside Inventory:</strong> <span id="lbl-army">None initialized yet.</span>
    </div>

    <!-- Pinned Informative System Poster Panel -->
    <div id="info-system-poster">
        <div class="poster-sec">
            <h4>📜 SYSTEM RULES</h4>
